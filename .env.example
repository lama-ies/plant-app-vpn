# Plantilla de variables de entorno de plant-app-vpn (frontend). Copiar a `.env` y rellenar.
# Solo variables con prefijo VITE_ llegan al cliente. NADA sensible aquí: la lógica de autorización vive
# en las lambdas; la lógica sensible de SO (WireGuard/SSH/SFTP) vive en el núcleo Rust.

# Base de la API (API Gateway). Recurso propio de esta app: /app-vpn/*.
VITE_API_BASE_URL=https://<API_ID>.execute-api.us-east-1.amazonaws.com

# Cognito — pool STAFF (app-vpn), independiente del pool del portal. Solo IDs públicos.
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_POOL_ID=<POOL_ID_STAFF>
VITE_COGNITO_CLIENT_ID=<CLIENT_ID_STAFF>
